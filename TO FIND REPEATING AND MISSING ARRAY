 // ek array diya hai of nums of size n 
      // har value bass ek baar ati hai array mai A ko CHOD KE and B hai vo missing hai 
      // YAHA A 0'th idx pe chahiye and B 1st 
      //matlab jo A hai vo hai repeated value and B hai Vo hai missing number 

class Solution {
public:
    vector<int> findMissingRepeatingNumbers(vector<int> nums) {
        int n = nums.size(); 
        vector<int> freq(n+1,0);

       for (int i = 0; i < n; i++) {
freq[nums[i]]++; 
} 
int A = -1, B = -1; 
for (int i = 1; i <= n; i++) {
if (freq[i] == 0) {
B = i; 
        } 
if (freq[i] > 1) { A = i; 
      } 
     } 
    return {A, B}; 
  }
};
