/* jar mazh ans/current element same ahe adhi chya element la kiva te less then ahe 
             adhi chya elemengt la trmerge krne continue krnar as ans.empty and ans.back()(1); continue krenge. 
           to keep all the intervals closer 
           jitne overlapping intervalles hai unhe merge kroo
            jo array hoga jo overlapp na hua ho usse hume return krna hai with all of the inverval in input 
            [1,3],[2,6],[8,10],[15,18] here 1st and 2nd block [1 to 6] will merge remaining will be same some 
            */

// BRUTE APPROACH
class Solution {
public:
    vector<vector<int>> merge(vector<vector<int>>& intervals) {
        int n = intervals.size(); 
         vector<vector<int>> ans; 
          sort(intervals.begin(), intervals.end()); 
        for(int i = 0; i<n; i++){
            int st = intervals[i][0];
            int end = intervals[i][1];
            if(!ans.empty() && end <= ans.back()[1]){
                continue; 
            } // new interval hoga create 
            for(int j = i+1; j<n; j++){
                if(intervals[j][0] <= end){
                    end = max(end,intervals[j][1]);
                }else{
                    break; 
                }
            }
            ans.push_back({st,end});
        }
        return ans; 
    }
};
// OPTIMAL 
/* jar apla starting cha element empty asel tyala koni prev element 
nasel chevk krnya sathi ki he moth ahe tya peksha ki chota then will only 
push the current element ani jar new interval asel ani to greater than last 
element asel tar update krnar ki maximum element jo ahe tith paryant tyachi 
pair asli pahije. */ 

class Solution {
public:
    vector<vector<int>> merge(vector<vector<int>>& intervals) {
        int n = intervals.size(); 
         vector<vector<int>> ans; 
          sort(intervals.begin(), intervals.end()); 
        for(int i = 0; i<n; i++){
           if(ans.empty()|| intervals[i][0] > ans.back()[1]){
              ans.push_back(intervals[i]); 
           }else{
            ans.back()[1] = max(ans.back()[1], intervals[i][1]);
           }
        }
        return ans; 
    }
};
