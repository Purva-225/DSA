// BRUTE APPROACH 
class Solution {
  public:
    long long inversionCount(vector<int> &arr) {
        int n = arr.size();
        long long cnt = 0;

        for (int i = 0; i < n - 1; i++) {
            for (int j = i + 1; j < n; j++) {
                if (arr[i] > arr[j]) {
                    cnt++;
                }
            }
        }

        return cnt;
    }
};
// Optimal one: 
class Solution {
public:

    int merge(vector<int> &arr, int low, int mid, int high) {
        vector<int> temp;
        int left = low;
        int right = mid + 1;
        int cnt = 0;

        while (left <= mid && right <= high) {
            if (arr[left] <= arr[right]) {
                temp.push_back(arr[left]);
                left++;
            }
            else {
                temp.push_back(arr[right]);
                cnt += (mid - left + 1); // Count 
                right++;
            }
        }

        while (left <= mid) {
            temp.push_back(arr[left]);
            left++;
        }

        while (right <= high) {
            temp.push_back(arr[right]);
            right++;
        }

        for (int i = low; i <= high; i++) {
            arr[i] = temp[i - low];
        }

        return cnt;
    }

    int mergeSort(vector<int> &arr, int low, int high) {
        if (low >= high) return 0;

        int mid = (low + high) / 2;

        int cnt = 0;
        cnt += mergeSort(arr, low, mid);       
        cnt += mergeSort(arr, mid + 1, high); 
        cnt += merge(arr, low, mid, high);     // Combined 

        return cnt;
    }

    int inversionCount(vector<int> &arr) {
        int n = arr.size();
        return mergeSort(arr, 0, n - 1);
    }
};
